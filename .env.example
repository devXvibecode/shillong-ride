# ShillongRide — Environment Configuration
#
# Copy this file to .env for local dev:
#   cp .env.example .env

# EmailJS Configuration (required for email notifications)
# Get your keys at https://www.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=service_shillongride
VITE_EMAILJS_TEMPLATE_ID=template_shillongride

# -------------------------------------------------------------------
# Cross-device booking sync (optional)
# -------------------------------------------------------------------
# To let the admin panel see bookings from all devices, create a
# GitHub Personal Access Token with "public_repo" scope and set it as:
#
#   VITE_GITHUB_TOKEN   <your GitHub PAT>
#
# When set, every booking is pushed to data/bookings.json in the repo
# and the admin panel fetches from there. Without it, bookings are
# stored locally only (per-device).
# -------------------------------------------------------------------

# GitHub Actions (for deployment)
# -------------------------------------------------------------------
# Add these as repository secrets in:
#   Settings → Secrets and variables → Actions → New repository secret
#
#   VITE_EMAILJS_PUBLIC_KEY   <your public key>
#   VITE_EMAILJS_SERVICE_ID   <your service ID>
#   VITE_EMAILJS_TEMPLATE_ID  <your template ID>
#   VITE_GITHUB_TOKEN         <your GitHub PAT>
#
# The deploy workflow will pass them as build env vars automatically.
# -------------------------------------------------------------------
